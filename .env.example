# ---------------------------------------------------------------------------
# ApexHolding Fakturácia — Environment Template
# ---------------------------------------------------------------------------
# Tento súbor je len TEMPLATE pre dokumentáciu.
# Aplikácia v súčasnosti NEPOUŽÍVA .env pri spustení (publishable key je
# hardcoded v apex-app.js, čo je bezpečné vďaka RLS).
#
# Ak by si v budúcnosti chcel build systém (Vite, Webpack), skopíruj tento
# súbor ako `.env` a vyplň reálne hodnoty. `.env` je v .gitignore.
# ---------------------------------------------------------------------------

# Supabase projektu
VITE_SUPABASE_URL=https://qszcrlptiwircitfuela.supabase.co

# Publishable / anon key (BEZPEČNÉ pre zobrazenie v klientskom kóde;
# dáta chráni Row Level Security v Postgres)
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Voliteľné — aplikáciové nastavenia (môžu byť prepísané v UI)
VITE_APP_NAME=ApexHolding Fakturácia
VITE_IDLE_TIMEOUT_MIN=10
VITE_LOGIN_MAX_ATTEMPTS=5
VITE_LOGIN_BLOCK_MIN=15
